CONTAINER_POSTGRES=stock-postgres
CONTAINER_REDIS=stock-redis
CONTAINER_BACKEND=stock-backend
CONTAINER_FRONTEND=stock-frontend
CONTAINER_CRAWLER=stock-crawler
CONTAINER_NGINX=stock-nginx

NETWORK_NAME=stock-network

VOLUME_POSTGRES=stock-postgres-data
VOLUME_REDIS=stock-redis-data

# Ports
DB_PORT=9227
REDIS_PORT=9327
CRAWLER_PORT=9627
FRONTEND_PORT=9727

# Database
DB_NAME=stock_analysis
DB_USER=stock_user
DB_PASSWORD=password

# Application
ENVIRONMENT=development
LOG_LEVEL=info
LOG_FORMAT=json

# Crawler
MAX_WORKERS=100
BATCH_SIZE=50
REQUEST_TIMEOUT=30s
SMART_SKIP_DAYS=1
ENABLE_METRICS=true

# Frontend
NUXT_PUBLIC_API_BASE=/api
